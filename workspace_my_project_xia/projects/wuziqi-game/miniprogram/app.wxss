/** app.wxss - 全局样式 */

/* 页面基础样式 */
page {
  height: 100%;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, sans-serif;
}

/* 容器 */
.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 按钮样式 */
.btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 400rpx;
  height: 90rpx;
  margin: 20rpx 0;
  border-radius: 45rpx;
  font-size: 32rpx;
  font-weight: 500;
  transition: all 0.3s ease;
}

.btn-primary {
  background: linear-gradient(135deg, #e94560 0%, #ff6b6b 100%);
  color: #fff;
  box-shadow: 0 8rpx 25rpx rgba(233, 69, 96, 0.4);
}

.btn-primary:active {
  transform: scale(0.95);
  box-shadow: 0 4rpx 15rpx rgba(233, 69, 96, 0.3);
}

.btn-secondary {
  background: linear-gradient(135deg, #0f3460 0%, #16213e 100%);
  color: #fff;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  box-shadow: 0 8rpx 25rpx rgba(0, 0, 0, 0.3);
}

.btn-secondary:active {
  transform: scale(0.95);
}

/* 标题样式 */
.title {
  font-size: 80rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 4rpx 20rpx rgba(233, 69, 96, 0.5);
  margin-bottom: 40rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 60rpx;
}
