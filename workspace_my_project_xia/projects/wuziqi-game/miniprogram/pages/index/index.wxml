<!--index.wxml - 首页 -->
<view class="container">
  <!-- 标题区域 -->
  <view class="header">
    <text class="title">五子棋</text>
    <text class="subtitle">经典策略对弈游戏</text>
  </view>

  <!-- 棋子装饰 -->
  <view class="chess-decoration">
    <view class="chess black-chess"></view>
    <view class="chess white-chess"></view>
  </view>

  <!-- 游戏模式选择 -->
  <view class="menu">
    <button class="btn btn-primary" bindtap="startPvE">
      <text>🎮 人机对战</text>
    </button>
    <button class="btn btn-secondary" bindtap="startPvP">
      <text>👥 双人对战</text>
    </button>
  </view>

  <!-- 游戏规则 -->
  <view class="rules" bindtap="showRules">
    <text class="rules-text">📖 游戏规则</text>
  </view>
</view>

<!-- 规则弹窗 -->
<view class="modal-mask" wx:if="{{showModal}}" bindtap="hideRules">
  <view class="modal-content" catchtap="preventClose">
    <view class="modal-header">
      <text class="modal-title">游戏规则</text>
    </view>
    <view class="modal-body">
      <view class="rule-item">
        <text class="rule-num">1</text>
        <text class="rule-text">黑棋先行，双方交替落子</text>
      </view>
      <view class="rule-item">
        <text class="rule-num">2</text>
        <text class="rule-text">在棋盘交叉点上落子</text>
      </view>
      <view class="rule-item">
        <text class="rule-num">3</text>
        <text class="rule-text">先连成五子的一方获胜</text>
      </view>
      <view class="rule-item">
        <text class="rule-num">4</text>
        <text class="rule-text">横、竖、斜均可连成五子</text>
      </view>
    </view>
    <button class="btn btn-primary modal-btn" bindtap="hideRules">知道了</button>
  </view>
</view>
