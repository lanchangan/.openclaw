/* index.wxss - 首页样式 */

.container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  min-height: 100vh;
  padding: 80rpx 40rpx;
  box-sizing: border-box;
}

/* 标题区域 */
.header {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 60rpx;
}

.title {
  font-size: 100rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 0 6rpx 30rpx rgba(233, 69, 96, 0.6);
  letter-spacing: 20rpx;
}

.subtitle {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 20rpx;
  letter-spacing: 4rpx;
}

/* 棋子装饰 */
.chess-decoration {
  display: flex;
  gap: 40rpx;
  margin: 60rpx 0;
}

.chess {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.3);
}

.black-chess {
  background: radial-gradient(circle at 30% 30%, #4a4a4a, #1a1a1a);
  border: 4rpx solid #333;
}

.white-chess {
  background: radial-gradient(circle at 30% 30%, #fff, #ddd);
  border: 4rpx solid #ccc;
}

/* 菜单区域 */
.menu {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 100%;
}

.menu .btn {
  width: 500rpx;
  height: 100rpx;
  margin: 15rpx 0;
  font-size: 34rpx;
}

/* 游戏规则 */
.rules {
  margin-bottom: 40rpx;
  padding: 20rpx 40rpx;
}

.rules-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.modal-content {
  width: 600rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 30rpx;
  padding: 40rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.5);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.modal-header {
  text-align: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #fff;
}

.modal-body {
  margin-bottom: 30rpx;
}

.rule-item {
  display: flex;
  align-items: center;
  margin: 20rpx 0;
}

.rule-num {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(135deg, #e94560 0%, #ff6b6b 100%);
  color: #fff;
  border-radius: 50%;
  font-size: 26rpx;
  font-weight: bold;
  margin-right: 20rpx;
}

.rule-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

.modal-btn {
  width: 100%;
  margin: 0;
}
