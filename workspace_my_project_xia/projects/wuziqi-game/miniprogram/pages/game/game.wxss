/* game.wxss - 游戏页面样式 */

.game-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  padding: 20rpx;
  box-sizing: border-box;
}

/* 游戏信息栏 */
.game-info {
  display: flex;
  justify-content: space-between;
  align-items: center;
  width: 100%;
  padding: 20rpx 30rpx;
  margin-bottom: 20rpx;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 20rpx;
}

.player-info {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 20rpx;
  border-radius: 15rpx;
  transition: all 0.3s ease;
}

.player-info.active {
  background: rgba(233, 69, 96, 0.2);
  box-shadow: 0 0 20rpx rgba(233, 69, 96, 0.3);
}

.chess-icon {
  width: 50rpx;
  height: 50rpx;
  border-radius: 50%;
  margin-bottom: 8rpx;
}

.chess-icon.black {
  background: radial-gradient(circle at 30% 30%, #4a4a4a, #1a1a1a);
  border: 2rpx solid #333;
}

.chess-icon.white {
  background: radial-gradient(circle at 30% 30%, #fff, #ddd);
  border: 2rpx solid #ccc;
}

.player-name {
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.player-status {
  font-size: 22rpx;
  color: #e94560;
  margin-top: 4rpx;
}

.game-status {
  flex: 1;
  text-align: center;
}

.status-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 棋盘区域 */
.board-wrapper {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #d4a574 0%, #c49660 50%, #b8895a 100%);
  border-radius: 20rpx;
  padding: 20rpx;
  box-shadow: 0 10rpx 40rpx rgba(0, 0, 0, 0.4),
              inset 0 2rpx 10rpx rgba(255, 255, 255, 0.2);
}

.chess-board {
  border-radius: 10rpx;
}

/* 操作按钮栏 */
.action-bar {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-top: 30rpx;
  padding: 20rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 160rpx;
  height: 70rpx;
  padding: 0 30rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 35rpx;
  font-size: 26rpx;
  color: #fff;
}

.action-btn.primary {
  background: linear-gradient(135deg, #e94560 0%, #ff6b6b 100%);
  border: none;
  box-shadow: 0 6rpx 20rpx rgba(233, 69, 96, 0.4);
}

.action-btn[disabled] {
  opacity: 0.4;
}

/* 结果弹窗 */
.result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.8);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.result-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 80rpx;
  background: linear-gradient(135deg, #1a1a2e 0%, #16213e 100%);
  border-radius: 40rpx;
  box-shadow: 0 30rpx 80rpx rgba(0, 0, 0, 0.5);
  border: 2rpx solid rgba(255, 255, 255, 0.1);
}

.result-icon {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 40rpx;
}

.result-actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.result-btn {
  width: 300rpx;
  height: 80rpx;
  line-height: 80rpx;
  background: rgba(255, 255, 255, 0.1);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
  border-radius: 40rpx;
  font-size: 30rpx;
  color: #fff;
}

.result-btn.primary {
  background: linear-gradient(135deg, #e94560 0%, #ff6b6b 100%);
  border: none;
}
