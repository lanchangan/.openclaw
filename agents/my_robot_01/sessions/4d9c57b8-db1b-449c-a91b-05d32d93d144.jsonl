ie_dict and '_m_h5_tk' in cookie_dict:\n                print()\n                print(\"✅ 检测到登录成功！\")\n                break\n            \n            elapsed += check_interval\n            page.wait_for_timeout(check_interval * 1000)\n            \n            # 显示进度\n            if elapsed % 10 == 0:\n                print(f\"  已等待 {elapsed} 秒...\")\n        \n        # 获取所有 Cookie\n        cookies = context.cookies()\n        cookie_dict = {c['name']: c['value'] for c in cookies}\n        \n        # 检查是否成功获取必要字段\n        if 'unb' not in cookie_dict or '_m_h5_tk' not in cookie_dict:\n            print()\n            print(\"❌ 超时未检测到登录，请重试\")\n            browser.close()\n            return None\n        \n        # 构建 Cookie 字符串\n        cookie_string = \"; \".join([f\"{c['name']}={c['value']}\" for c in cookies])\n        \n        print()\n        print(\"✅ Cookie 提取成功！\")\n        print()\n        \n        # 保存到配置文件\n        config = {\n            \"cookie\": cookie_string,\n            \"created_at\": str(Path.home() / \".xianyu-agent\"),\n            \"auto_reply\": True,\n            \"simulate_typing\": False,\n            \"heartbeat_interval\": 15,\n            \"message_expire_time\": 300000\n        }\n        \n        config_path = xianyu_dir / \"config.json\"\n        with open(config_path, 'w', encoding='utf-8') as f:\n            json.dump(config, f, ensure_ascii=False, indent=2)\n        \n        print(f\"📁 配置文件已保存：{config_path}\")\n        print()\n        \n        # 验证关键字段\n        print(\"Cookie 验证：\")\n        print(f\"  - 用户 ID (unb): {cookie_dict.get('unb', '❌ 缺失')[:10]}...\")\n        print(f\"  - Token (_m_h5_tk): {cookie_dict.get('_m_h5_tk', '❌ 缺失')[:20]}...\")\n        print()\n        \n        browser.close()\n        \n        return cookie_string\n\nif __name__ == \"__main__\":\n    try:\n        cookie = get_cookie()\n        if cookie:\n            print(\"🎉 Cookie 获取完成！可以启动自动回复服务了~\")\n            sys.exit(0)\n        else: