{"type":"message","id":"1a92ddb7","parentId":"8e777f23","timestamp":"2026-03-17T00:10:18.381Z","message":{"role":"toolResult","toolCallId":"call_t3n1j2fgouriilz1tq86dfh9","toolName":"read","content":[{"type":"text","text":"# OpenClaw 配置文件\n# 生成时间: 2026-03-16\n\n# ====================\n# 搜索 API 配置\n# ====================\nweb:\n  # 默认使用的搜索提供商 (brave 或 tavily)\n  default_provider: tavily\n  \n  # Brave Search 配置 (可选)\n  # 如需使用 Brave, 取消注释并填入 API Key\n  # brave:\n  #   api_key: \"BSAxxxxxxxxxxxxxxxx\"\n  #   max_results: 10\n  \n  # Tavily Search 配置 (已启用)\n  tavily:\n    api_key: \"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\"\n    max_results: 10\n    search_depth: \"advanced\"  # 可选: basic 或 advanced\n\n# ====================\n# 其他配置项\n# ====================\n# 模型配置\n# model:\n#   default: \"gpt-4\"\n#   temperature: 0.7\n\n# 日志配置\n# logging:\n#   level: \"info\"\n#   file: \"~/.openclaw/logs/openclaw.log\"\n"}],"isError":false,"timestamp":1773706218380}}
