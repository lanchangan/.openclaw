{"type":"message","id":"95b61c35","parentId":"399a0d65","timestamp":"2026-03-16T15:46:06.257Z","message":{"role":"toolResult","toolCallId":"exec:36","toolName":"exec","content":[{"type":"text","text":"[?9001h[?1004h[?25l[2J[m[HUsage: clawhub [options] [command][36m[1m[3;1HClawHub CLI v0.8.0[m[2m\r\ninstall, update, search, and publish agent skills.[22m[6;1HOptions:\r\n[33m[2C-V, --cli-version                       [mShow CLI version\r\n[33m[2C--workdir <dir>                         [mWorking directory (default: cwd)\r\n[33m[2C--dir <dir>                             [mSkills directory (relative to workdir, default: skills)\r\n[33m[2C--site <url>                            [mSite base URL (for browser login)\r\n[33m[2C--registry <url>                        [mRegistry API base URL\r\n[33m[2C--no-input                              [mDisable prompts\r\n[33m[2C-h, --help                              [mdisplay help for command[15;1HCommands:\r\n  login [options]                         Log in (opens browser or stores token)\r\n  logout                                  Remove stored token\r\n  whoami                                  Validate token\r\n  auth                                    Authentication commands\r\n  search [options] <query...>             Vector search skills\r\n  install [options] <slug>                Install into <dir>/<slug>\r\n  update [options] [slug]                 Update installed skills\r\n  uninstall [options] <slug>              Uninstall a skill\r\n  list                                    List installed skills (from lockfile)\r\n  explore [options]                       Browse latest updated skills from the registry\r\n  inspect [options] <slug>                Fetch skill metadata and files without installing\r\n  publish [options] <path>                Publish skill from folder\r\n  delete [options] <slug>                 Soft-delete a skill (owner, moderator, or admin)\r\n  hide [options] <slug>                   Hide a skill (owner, moderator, or admin)\r\n  undelete [options] <slug>               Restore a hidden skill (owner, moderator, or admin)\r]0;C:\\Program Files\\PowerShell\\7\\pwsh.exe[?25h\n  unhide [options] <slug>                 Unhide a skill (owner, moderator, or admin)\r\n  ban-user [options] <handleOrId>         Ban a user and delete owned skills (moderator/admin only)\r\n  set-role [options] <handleOrId> <role>  Change a user role (admin only)\r\n  transfer                                Transfer skill ownership\r\n  star [options] <slug>                   Add a skill to your highlights\r\n  unstar [options] <slug>                 Remove a skill from your highlights\r\n  sync [options]                          Scan local skills and publish new/updated ones\r\n\n[2mEnv:[22m[K\r\n[2m  CLAWHUB_SITE[22m[K\r\n[2m  CLAWHUB_REGISTRY[22m[K\r\n[2m  CLAWHUB_WORKDIR[22m[K\r\n[2m  (CLAWDHUB_* supported)[22m[K"}],"details":{"status":"completed","exitCode":0,"durationMs":2961,"aggregated":"[?9001h[?1004h[?25l[2J[m[HUsage: clawhub [options] [command][36m[1m[3;1HClawHub CLI v0.8.0[m[2m\r\ninstall, update, search, and publish agent skills.[22m[6;1HOptions:\r\n[33m[2C-V, --cli-version                       [mShow CLI version\r\n[33m[2C--workdir <dir>                         [mWorking directory (default: cwd)\r\n[33m[2C--dir <dir>                             [mSkills directory (relative to workdir, default: skills)\r\n[33m[2C--site <url>                            [mSite base URL (for browser login)\r\n[33m[2C--registry <url>                        [mRegistry API base URL\r\n[33m[2C--no-input                              [mDisable prompts\r\n[33m[2C-h, --help                              [mdisplay help for command[15;1HCommands:\r\n  login [options]                         Log in (opens browser or stores token)\r\n  logout                                  Remove stored token\r\n  whoami                                  Validate token\r\n  auth                                    Authentication comm