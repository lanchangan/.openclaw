{"type":"message","id":"d1498645","parentId":"71f51d60","timestamp":"2026-03-18T14:53:46.409Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"让我用更直接的方式处理这个问题。我需要：\n\n1. 首先确保安装了 ffmpeg（Whisper 依赖它来读取视频文件）\n2. 然后使用 Python 脚本来提取音频并转录\n\n让我创建一个新的简化版脚本：","thinkingSignature":"reasoning_content"},{"type":"text","text":"让我创建一个简化的脚本，使用 pydub 来提取音频，然后用 Whisper 转录："},{"type":"toolCall","id":"write:123","name":"write","arguments":{"path":"C:\\Users\\LWS\\.openclaw\\workspace\\simple_transcribe.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n简单版视频转逐字稿 - 使用 pydub + Whisper\n\"\"\"\nimport os\nimport sys\nimport subprocess\nimport json\nfrom datetime import datetime\n\n# 设置UTF-8编码\nsys.stdout.reconfigure(encoding='utf-8')\n\nprint(\"=\" * 70)\nprint(\"视频转逐字稿工具 (简化版)\")\nprint(\"=\" * 70)\n\n# 安装必要的依赖\nprint(\"\\n[步骤1] 检查并安装依赖...\")\nrequired_packages = ['pydub', 'openai-whisper', 'ffmpeg-python']\nfor pkg in required_packages:\n    try:\n        __import__(pkg.replace('-', '_').replace('ffmpeg-python', 'ffmpeg'))\n        print(f\"  [OK] {pkg}\")\n    except ImportError:\n        print(f\"  [安装] {pkg}...\")\n        subprocess.run([sys.executable, \"-m\", \"pip\", \"install\", pkg, \"-q\"])\n\n# 重新导入\nfrom pydub import AudioSegment\nimport whisper\n\n# 查找视频文件\nvideo_dir = \"bili_download\"\nvideo_files = []\n\nif os.path.exists(video_dir):\n    for f in os.listdir(video_dir):\n        if f.endswith('.mp4'):\n            video_files.append(os.path.join(video_dir, f))\n\nvideo_files.sort()\n\nif not video_files:\n    print(f\"\\n错误: 未找到视频文件\")\n    exit(1)\n\nprint(f\"\\n找到 {len(video_files)} 个视频文件\")\n\n# 提取音频\nprint(\"\\n[步骤2] 从视频提取音频...\")\naudio_files = []\n\nfor i, video_path in enumerate(video_files, 1):\n    print(f\"\\n  处理视频 {i}/{len(video_files)}\")\n    \n    audio_path = os.path.join(output_dir, f\"audio_{i:02d}.wav\")\n    audio_files.append(audio_path)\n    \n    try:\n        # 使用 pydub 提取音频\n        print(f\"    加载视频...\")\n        video = AudioSegment.from_file(video_path, format=\"mp4\")\n        \n        # 转换为单声道, 16kHz (Whisper推荐)\n        print(f\"    转换格式 (16kHz, 单声道)...\")\n        video = video.set_channels(1)\n        video = video.set_frame_rate(16000)\n        \n        # 导出WAV\n        print(f\"    保存音频...\")\n        video.export(audio_path, format=\"wav\")\n        \n        file_size = os.path.getsize(audio_path) / (1024*1024)\n        print(f\"    [OK] 音频已保存: {file_size:.1f} MB\")\n        \n    except Exception as e:\n        print(f\"    [错误] {e}\")\n        import traceback\n        traceback.print_exc()\n\n# 使用Whisper识别\nprint(\"\\n[步骤3] Whisper语音识别...\")\n\nprint(\"  加载模型 (base)...\")\nmodel = whisper.load_model(\"base\")\nprint(\"  [OK] 模型加载完成\\n\")\n\nall_results = []\n\nfor i, audio_path in enumerate(audio_files, 1):\n    if not os.path.exists(audio_path):\n        print(f\"  跳过 {i}: 音频文件不存在\")\n        continue\n    \n    print(f\"  识别音频 {i}/{len(audio_files)}...\")\n    \n    try:\n        result = model.transcribe(\n            audio_path,\n            language=\"zh\",\n            verbose=False,\n            fp16=False\n        )\n        \n        all_results.append(result)\n        \n        duration = result.get('duration', 0)\n        segments = len(result.get('segments', []))\n        \n        print(f\"    [OK] 识别完成: {duration:.1f}秒, {segments}段\\n\")\n        \n    except Exception as e:\n        print(f\"    [错误] {e}\\n\")\n\nif not all_results:\n    print(\"错误: 没有识别结果\")\n    exit(1)\n\n# 生成逐字稿文件\nprint(\"\\n[步骤4] 生成逐字稿文件...\")\n\n# 1. 带时间戳版本\ntimestamp_file = \"逐字稿-看看我们的地球导读课-带时间戳.txt\"\nwith open(timestamp_file, 'w', encoding='utf-8') as f:\n    f.write(\"=\" * 70 + \"\\n\")\n    f.write(\"逐字稿（带时间戳）\\n\")\n    f.write(\"=\" * 70 + \"\\n\\n\")\n    f.write(f\"视频标题: 四年级下册《看看我们的地球》导读课-王秀萍\\n\")\n    f.write(f\"视频链接: https://www.bilibili.com/video/BV1u61mBhEj7/\\n\")\n    f.write(f\"识别方式: Whisper AI语音识别\\n\")\n    f.write(f\"生成时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\\n\\n\")\n    f.write(\"=\" * 70 + \"\\n正文\\n\" + \"=\" * 70 + \"\\n\\n\")\n    \n    for idx, result in enumerate(all_results, 1):\n        if len(all_results) > 1:\n            f.write(f\"\\n--- 第{idx}部分 ---\\n\\n\")\n        for seg in result.get('segments', []):\n            start = seg['start']\n            text = seg['text'].strip()\n            if text:\n                mins = int(start // 60)\n                secs = int(start % 60)\n                f.write(f\"[{mins:02d}:{secs:02d}] {text}\\n\")\n\nprint(f\"  [OK] {timestamp_file}\")\n\n# 2. 纯文本版本\npure_file = \"逐字稿-看看我们的地球导读课.txt\"\nwith open(pure_file, 'w', encoding='utf-8') as f:\n    f.write(\"=\" * 70 + \"\\n\")\n    f.write(\"逐字稿\\n\")\n    f.write(\"=\" * 70 + \"\\n\\n\")\n    f.write(f\"视频标题: 四年级下册《看看我们的地球》导读课-王秀萍\\n\")\n    f.write(f\"视频链接: https://www.bilibili.com/video/BV1u61mBhEj7/\\n\")\n    f.write(f\"识别方式: Whisper AI语音识别\\n\")\n    f.write(f\"生成时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\\n\\n\")\n    f.write(\"=\" * 70 + \"\\n正文\\n\" + \"=\" * 70 + \"\\n\\n\")\n    \n    for idx, result in enumerate(all_results, 1):\n        if len(all_results) > 1:\n            f.write(f\"\\n--- 第{idx}部分 ---\\n\\n\")\n        f.write(result.get('text', '').strip() + \"\\n\")\n\nprint(f\"  [OK] {pure_file}\")\n\n# 3. SRT字幕\nsrt_file = \"逐字稿-看看我们的地球导读课.srt\"\ndef secs_to_srt(secs):\n    hrs = int(secs // 3600)\n    mins = int((secs % 3600) // 60)\n    secs_int = int(secs % 60)\n    millis = int((secs % 1) * 1000)\n    return f\"{hrs:02d}:{mins:02d}:{secs_int:02d},{millis:03d}\"\n\nwith open(srt_file, 'w', encoding='utf"}}],"api":"openai-completions","provider":"volcengine-plan","model":"kimi-k2.5","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"aborted","timestamp":1773845479565,"errorMessage":"Request was aborted"}}
