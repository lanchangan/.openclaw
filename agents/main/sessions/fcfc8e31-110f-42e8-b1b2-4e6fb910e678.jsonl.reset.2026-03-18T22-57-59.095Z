{"type":"message","id":"f30c38a0","parentId":"303ae7c6","timestamp":"2026-03-18T14:51:02.959Z","message":{"role":"assistant","content":[{"type":"thinking","thinking":"看来 moviepy 安装后还是无法导入。让我直接用 Whisper 读取视频文件，因为 Whisper 可以直接处理视频：让我修改脚本直接用 Whisper 处理视频文件，跳过音频提取步骤。","thinkingSignature":"reasoning_content"},{"type":"toolCall","id":"write:118","name":"write","arguments":{"path":"C:\\Users\\LWS\\.openclaw\\workspace\\whisper_direct.py","content":"#!/usr/bin/env python3\n# -*- coding: utf-8 -*-\n\"\"\"\n直接使用Whisper处理视频文件生成逐字稿\nWhisper可以直接读取视频，不需要先提取音频\n\"\"\"\nimport os\nimport sys\nimport json\nfrom datetime import datetime\n\n# 设置UTF-8编码\nsys.stdout.reconfigure(encoding='utf-8')\n\nprint(\"=\" * 70)\nprint(\"Whisper视频转逐字稿\")\nprint(\"=\" * 70)\n\n# 查找视频文件\nvideo_dir = \"bili_download\"\nvideo_files = []\n\nif os.path.exists(video_dir):\n    for f in os.listdir(video_dir):\n        if f.endswith('.mp4'):\n            video_files.append(os.path.join(video_dir, f))\n\nvideo_files.sort()\n\nif not video_files:\n    print(f\"\\n错误: 在 {video_dir} 目录中未找到MP4视频文件\")\n    exit(1)\n\nprint(f\"\\n找到 {len(video_files)} 个视频文件:\")\nfor i, vf in enumerate(video_files, 1):\n    size_mb = os.path.getsize(vf) / (1024*1024)\n    print(f\"  [{i}] {os.path.basename(vf)} ({size_mb:.1f} MB)\")\n\n# 导入Whisper\nprint(\"\\n\" + \"=\" * 70)\nprint(\"加载Whisper模型...\")\nprint(\"=\" * 70)\n\ntry:\n    import whisper\n    print(\"[OK] Whisper已安装\")\nexcept ImportError:\n    print(\"[X] Whisper未安装，正在安装...\")\n    import subprocess\n    subprocess.run([sys.executable, \"-m\", \"pip\", \"install\", \"-U\", \"openai-whisper\", \"-q\"])\n    import whisper\n    print(\"[OK] Whisper安装完成\")\n\nprint(\"\\n加载base模型(适合中文识别)...\")\nmodel = whisper.load_model(\"base\")\nprint(\"[OK] 模型加载完成!\")\n\n# 处理每个视频\nprint(\"\\n\" + \"=\" * 70)\nprint(\"开始语音识别\")\nprint(\"=\" * 70)\n\nall_results = []\n\nfor i, video_path in enumerate(video_files, 1):\n    print(f\"\\n{'='*70}\")\n    print(f\"处理视频 {i}/{len(video_files)}\")\n    print(f\"文件: {os.path.basename(video_path)}\")\n    print(f\"{'='*70}\")\n    \n    try:\n        print(\"\\n正在进行语音识别...\")\n        print(\"(这可能需要几分钟，取决于视频时长)\\n\")\n        \n        # 使用Whisper识别\n        result = model.transcribe(\n            video_path,\n            language=\"zh\",      # 中文\n            verbose=True,       # 显示进度\n            fp16=False          # CPU模式\n        )\n        \n        all_results.append(result)\n        \n        # 显示结果统计\n        duration = result.get('duration', 0)\n        segments = len(result.get('segments', []))\n        text_len = len(result.get('text', ''))\n        \n        print(f\"\\n[OK] 识别完成!\")\n        print(f\"     视频时长: {duration:.1f}秒 ({duration/60:.1f}分钟)\")\n        print(f\"     识别段落: {segments}个\")\n        print(f\"     文字数量: {text_len}字\")\n        \n    except Exception as e:\n        print(f\"\\n[错误] 识别失败: {e}\")\n        import traceback\n        traceback.print_exc()\n\n# 如果没有识别结果，退出\nif not all_results:\n    print(\"\\n错误: 没有识别到任何内容\")\n    exit(1)\n\n# 生成最终逐字稿文件\nprint(\"\\n\" + \"=\" * 70)\nprint(\"生成逐字稿文件\")\nprint(\"=\" * 70)\n\n# 1. 生成带时间戳的逐字稿\ntimestamp_file = \"逐字稿-看看我们的地球导读课-带时间戳.txt\"\nprint(f\"\\n[1] 生成: {timestamp_file}\")\n\nwith open(timestamp_file, 'w', encoding='utf-8') as f:\n    f.write(\"=\" * 70 + \"\\n\")\n    f.write(\"逐字稿（带时间戳）\\n\")\n    f.write(\"=\" * 70 + \"\\n\\n\")\n    f.write(f\"视频标题: 四年级下册《看看我们的地球》导读课-王秀萍\\n\")\n    f.write(f\"视频链接: https://www.bilibili.com/video/BV1u61mBhEj7/\\n\")\n    f.write(f\"识别方式: Whisper AI语音识别\\n\")\n    f.write(f\"生成时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\\n\\n\")\n    f.write(\"=\" * 70 + \"\\n\")\n    f.write(\"正文\\n\")\n    f.write(\"=\" * 70 + \"\\n\\n\")\n    \n    for part_idx, result in enumerate(all_results, 1):\n        if len(all_results) > 1:\n            f.write(f\"\\n--- 第{part_idx}部分 ---\\n\\n\")\n        \n        for segment in result.get('segments', []):\n            start = segment['start']\n            text = segment['text'].strip()\n            \n            if text:\n                mins = int(start // 60)\n                secs = int(start % 60)\n                time_str = f\"{mins:02d}:{secs:02d}\"\n                f.write(f\"[{time_str}] {text}\\n\")\n\nprint(f\"    [OK] 文件大小: {os.path.getsize(timestamp_file)/1024:.1f} KB\")\n\n# 2. 生成纯文本逐字稿 (无时间戳)\npure_file = \"逐字稿-看看我们的地球导读课.txt\"\nprint(f\"\\n[2] 生成: {pure_file}\")\n\nwith open(pure_file, 'w', encoding='utf-8') as f:\n    f.write(\"=\" * 70 + \"\\n\")\n    f.write(\"逐字稿\\n\")\n    f.write(\"=\" * 70 + \"\\n\\n\")\n    f.write(f\"视频标题: 四年级下册《看看我们的地球》导读课-王秀萍\\n\")\n    f.write(f\"视频链接: https://www.bilibili.com/video/BV1u61mBhEj7/\\n\")\n    f.write(f\"识别方式: Whisper AI语音识别\\n\")\n    f.write(f\"生成时间: {datetime.now().strftime('%Y-%m-%d %H:%M:%S')}\\n\\n\")\n    f.write(\"=\" * 70 + \"\\n\")\n    f.write(\"正文\\n\")\n    f.write(\"=\" * 70 + \"\\n\\n\")\n    \n    for part_idx, result in enumerate(all_results, 1):\n        if len(all_results) > 1:\n            f.write(f\"\\n--- 第{part_idx}部分 ---\\n\\n\")\n        \n        # 获取完整文本\n        full_text = result.get('text', '').strip()\n        f.write(full_text + \"\\n\")\n\nprint(f\"    [OK] 文件大小: {os.path.getsize(pure_file)/1024:.1f} KB\")\n\n# 3. 生成SRT字幕文件\nsrt_file = \"逐字稿-看看我们的地球导读课.srt\"\nprint(f\"\\n[3] 生成: {srt_file}\")\n\ndef secs_to_srt(secs):\n    hrs = int(secs // 3600)\n    mins = int((secs % 3600) // 60)\n    secs_int = int(secs % 60)\n    millis = int((secs % 1) * 1000)\n    return f\"{hrs:02d}:{mins:02d}:{secs_int:02d},{millis:03d}\"\n\nwith open(srt_file, 'w', encoding='utf-8') as f:\n    idx = 1\n    for result in all_results:\n        for segment in result.get('segments', []):\n            start = segment['start']\n            end = segment['end']\n            text = segment['text'].strip()\n            \n            if text:\n                f.write(f\"{idx}\\n\")\n                f.write(f\"{secs_to_srt(start)} --> {secs_to_srt(end)}\\n\")\n                f.write(f\"{text}\\n\\n\")\n                idx += 1\n\nprint(f\"    [OK] 文件大小: {os.path.getsize(srt_file)/1024:.1f} KB\")\n\n# 4. 保存JSON格式 (完整数据)\njson_file = \"逐字稿-看看我们的地球导读课.json\"\nprint(f\"\\n[4] 生成: {json_file}\")\n\ncombined_data = {\n    \"video_info\": {\n        \"title\": \"四年级下册《看看我们的地球》导读课-王秀萍\",\n        \"bvid\": bvid,\n        \"url\": f\"https://www.bilibili.com/video/{bvid}/\",\n        \"parts\": len(all_results)\n    },\n    \"transcription\": {\n        \"engine\": \"Whisper\",\n        \"model\": \"base\",\n        \"language\": \"zh\",\n        \"generated_at\": datetime.now().strftime('%Y-%m-%d %H:%M:%S')\n    },\n    \"results\": all_results\n}\n\nwith open(json_file, 'w', encoding='utf-8') as f:\n    json.dump(combined_data, f, ensure_ascii=False, indent=2)\n\nprint(f\"    [OK] 文件大小: {os.path.getsize(json_file)/1024:.1f} KB\")\n\n# 生成完成摘要\nprint(\"\\n\" + \"=\" * 70)\nprint(\"所有文件生成完成!\")\nprint(\"=\" * 70)\nprint(\"\\n生成的文件列表:\")\nprint(f\"  1. {timestamp_file} (带时间戳的逐字稿)\")\nprint(f\"  2. {pure_file} (纯文本逐字稿)\")\nprint(f\"  3. {srt_file} (SRT字幕文件)\")\nprint(f\"  4. {json_file} (完整数据JSON)\")\n\n# 统计信息\ntotal_duration = sum(r.get('duration', 0) for r in all_results)\ntotal_segments = sum(len(r.get('segments', [])) for r in all_results)\ntotal_chars = sum(len(r.get('text', '')) for r in all_results)\n\nprint(f\"\\n统计信息:\")\nprint(f\"  视频总时长: {total_duration:.1f}秒 ({total_duration/60:.1f}分钟)\")\nprint(f\"  识别段落数: {total_segments}个\")\nprint(f\"  总字数: {total_chars}字\")\nprint(f\"  视频分段数: {len(all_results)}段\")\n\nprint(\"\\n\" + \"=\" * 70)\n"}},{"type":"toolCall","id":"exec:119","name":"exec","arguments":{"command":"C:\\Python314\\python.exe extract_and_transcribe_full.py 2>&1 | more","workdir":"C:\\Users\\LWS\\.openclaw\\workspace","timeout":1800}}],"api":"openai-completions","provider":"volcengine-plan","model":"kimi-k2.5","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"toolUse","timestamp":1773845275767}}
