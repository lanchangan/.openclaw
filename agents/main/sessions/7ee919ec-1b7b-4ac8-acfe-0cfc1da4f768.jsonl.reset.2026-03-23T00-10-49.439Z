{"type":"message","id":"d82ddef3","parentId":"7ff8f746","timestamp":"2026-03-22T14:09:53.020Z","message":{"role":"assistant","content":[{"type":"toolCall","id":"write:10","name":"write","arguments":{"path":"C:\\Users\\LWS\\.openclaw\\workspace\\create_ppt.py","content":"from pptx import Presentation\nfrom pptx.util import Inches, Pt\nfrom pptx.enum.text import PP_ALIGN\nfrom pptx.enum.shapes import MSO_SHAPE\nimport os\n\n# еҲӣе»әжј”зӨәж–ҮзЁҝ\nprs = Presentation()\nprs.slide_width = Inches(13.333)\nprs.slide_height = Inches(7.5)\n\ndef set_shape_color(shape, r, g, b):\n    \"\"\"и®ҫзҪ®еҪўзҠ¶еЎ«е……йўңиүІ\"\"\"\n    from pptx.dml.color import RGBColor\n    shape.fill.solid()\n    shape.fill.fore_color.rgb = RGBColor(r, g, b)\n\ndef set_text_color(run, r, g, b):\n    \"\"\"и®ҫзҪ®ж–Үеӯ—йўңиүІ\"\"\"\n    from pptx.dml.color import RGBColor\n    run.font.color.rgb = RGBColor(r, g, b)\n\n# е®ҡд№үйўңиүІж–№жЎҲ\nPRIMARY_R, PRIMARY_G, PRIMARY_B = 255, 152, 0\nSECONDARY_R, SECONDARY_G, SECONDARY_B = 255, 193, 7\nTEXT_R, TEXT_G, TEXT_B = 55, 71, 79\nWHITE_R, WHITE_G, WHITE_B = 255, 255, 255\n\ndef add_title_slide(title, subtitle=\"\"):\n    \"\"\"ж·»еҠ ж ҮйўҳйЎө\"\"\"\n    slide_layout = prs.slide_layouts[6]\n    slide = prs.slides.add_slide(slide_layout)\n    \n    bg = slide.shapes.add_shape(MSO_SHAPE.RECTANGLE, 0, 0, prs.slide_width, prs.slide_height)\n    set_shape_color(bg, PRIMARY_R, PRIMARY_G, PRIMARY_B)\n    bg.line.fill.background()\n    \n    circle1 = slide.shapes.add_shape(MSO_SHAPE.OVAL, Inches(10), Inches(-1), Inches(4), Inches(4))\n    set_shape_color(circle1, SECONDARY_R, SECONDARY_G, SECONDARY_B)\n    circle1.line.fill.background()\n    \n    title_box = slide.shapes.add_textbox(Inches(1), Inches(2.5), Inches(11), Inches(1.5))\n    tf = title_box.text_frame\n    p = tf.paragraphs[0]\n    p.text = title\n    p.font.size = Pt(60)\n    p.font.bold = True\n    set_text_color(p, WHITE_R, WHITE_G, WHITE_B)\n    p.alignment = PP_ALIGN.CENTER\n    \n    if subtitle:\n        sub_box = slide.shapes.add_textbox(Inches(1), Inches(4.2), Inches(11), Inches(1))\n        tf = sub_box.text_frame\n        p = tf.paragraphs[0]\n        p.text = subtitle\n        p.font.size = Pt(32)\n        set_text_color(p, WHITE_R, WHITE_G, WHITE_B)\n        p.alignment = PP_ALIGN.CENTER\n    \n    return slide\n\ndef add_content_slide(title, content_list, emoji=\"\"):\n    \"\"\"ж·»еҠ еҶ…е®№йЎө\"\"\"\n    slide_layout = prs.slide_layouts[6]\n    slide = prs.slides.add_slide(slide_layout)\n    \n    bg = slide.shapes.add_shape(MSO_SHAPE.RECTANGLE, 0, 0, prs.slide_width, prs.slide_height)\n    set_shape_color(bg, WHITE_R, WHITE_G, WHITE_B)\n    bg.line.fill.background()\n    \n    top_bar = slide.shapes.add_shape(MSO_SHAPE.RECTANGLE, 0, 0, prs.slide_width, Inches(0.15))\n    set_shape_color(top_bar, PRIMARY_R, PRIMARY_G, PRIMARY_B)\n    top_bar.line.fill.background()\n    \n    title_bg = slide.shapes.add_shape(MSO_SHAPE.ROUNDED_RECTANGLE, Inches(0.5), Inches(0.4), Inches(12.3), Inches(1.1))\n    set_shape_color(title_bg, SECONDARY_R, SECONDARY_G, SECONDARY_B)\n    title_bg.line.fill.background()\n    \n    title_box = slide.shapes.add_textbox(Inches(0.7), Inches(0.55), Inches(11.9), Inches(0.9))\n    tf = title_box.text_frame\n    p = tf.paragraphs[0]\n    p.text = f\"{emoji} {title}\" if emoji else title\n    p.font.size = Pt(40)\n    p.font.bold = True\n    p.font.color.rgb = TEXT_COLOR\n    \n    content_box = slide.shapes.add_textbox(Inches(0.8), Inches(1.8), Inches(11.7), Inches(5.2))\n    tf = content_box.text_frame\n    tf.word_wrap = True\n    \n    for i, item in enumerate(content_list):\n        if i == 0:\n            p = tf.paragraphs[0]\n        else:\n            p = tf.add_paragraph()\n        p.text = item\n        p.font.size = Pt(28) if len(item) < 50 else Pt(24)\n        p.font.color.rgb = TEXT_COLOR\n        p.space_after = Pt(16)\n    \n    return slide\n\ndef add_story_slide(title, story_text, page_num=\"\"):\n    \"\"\"ж·»еҠ ж•…дәӢйЎө\"\"\"\n    slide_layout = prs.slide_layouts[6]\n    slide = prs.slides.add_slide(slide"}}],"api":"openai-completions","provider":"volcengine-plan","model":"kimi-k2.5","usage":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"totalTokens":0,"cost":{"input":0,"output":0,"cacheRead":0,"cacheWrite":0,"total":0}},"stopReason":"aborted","timestamp":1774188535290,"errorMessage":"Request was aborted"}}
