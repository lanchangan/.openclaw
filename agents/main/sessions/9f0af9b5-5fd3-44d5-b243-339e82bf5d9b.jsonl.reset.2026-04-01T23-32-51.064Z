   \"cost\": {\n              \"input\": 0,\n              \"output\": 0,\n              \"cacheRead\": 0,\n              \"cacheWrite\": 0\n            },\n            \"contextWindow\": 196608,\n            \"maxTokens\": 32768\n          },\n          {\n            \"id\": \"kimi-k2.5\",\n            \"name\": \"Kimi-K2.5\",\n            \"reasoning\": false,\n            \"input\": [\n              \"text\"\n            ],\n            \"cost\": {\n              \"input\": 0,\n              \"output\": 0,\n              \"cacheRead\": 0,\n              \"cacheWrite\": 0\n            },\n            \"contextWindow\": 262144,\n            \"maxTokens\": 32768\n          }\n        ]\n      }\n    }\n  },\n  \"agents\": {\n    \"defaults\": {\n      \"model\": {\n        \"primary\": \"custom-43-133-33-215-3000/glm-5\",\n        \"fallbacks\": []\n      },\n      \"models\": {\n        \"custom-43-133-33-215-3000/glm-5\": {\n          \"alias\": \"glm5\"\n        },\n        \"custom-43-133-33-215-3000/tc-code-latest\": {\n          \"alias\": \"auto\"\n        },\n        \"custom-43-133-33-215-3000/hunyuan-2.0-instruct\": {},\n        \"custom-43-133-33-215-3000/hunyuan-2.0-thinking\": {},\n        \"custom-43-133-33-215-3000/hunyuan-t1\": {},\n        \"custom-43-133-33-215-3000/hunyuan-turbos\": {},\n        \"custom-43-133-33-215-3000/minimax-m2.5\": {\n          \"alias\": \"minimax\"\n        },\n        \"custom-43-133-33-215-3000/kimi-k2.5\": {\n          \"alias\": \"kimi\"\n        }\n      },\n      \"workspace\": \"C:\\\\Users\\\\LWS\\\\.openclaw\\\\workspace\",\n      \"compaction\": {\n        \"mode\": \"safeguard\",\n        \"keepRecentTokens\": 20000\n      }\n    },\n    \"list\": [\n      {\n        \"id\": \"main\",\n        \"model\": \"custom-43-133-33-215-3000/glm-5\"\n      },\n      {\n        \"id\": \"my_robot_01\",\n        \"name\": \"my_robot_01\",\n        \"workspace\": \"C:\\\\Users\\\\LWS\\\\.openclaw\\\\workspace-my_robot_01\",\n        \"agentDir\": \"C:\\\\Users\\\\LWS\\\\.openclaw\\\\agents\\\\my_robot_01\\\\agent\",\n        \"model\": \"minimax\"\n      },\n      {\n        \"id\": \"my_xiaohongshu\",\n        \"name\": \"my_xiaohongshu\",\n        \"workspace\": \"C:\\\\Users\\\\LWS\\\\.openclaw\\\\workspace-my_xiaohongshu\",\n        \"agentDir\": \"C:\\\\Users\\\\LWS\\\\.openclaw\\\\agents\\\\my_xiaohongshu\\\\agent\",\n        \"model\": \"kimi\"\n      },\n      {\n        \"id\": \"my_kuailexia\",\n        \"name\": \"my_kuailexia\",\n        \"workspace\": \"C:\\\\Users\\\\LWS\\\\.openclaw\\\\workspace-my_kuailexia\",\n        \"agentDir\": \"C:\\\\Users\\\\LWS\\\\.openclaw\\\\agents\\\\my_kuailexia\\\\agent\",\n        \"model\": \"kimi\"\n      },\n      {\n        \"id\": \"my_work_robot\",\n        \"name\": \"my_work_robot\",\n        \"workspace\": \"C:\\\\Users\\\\LWS\\\\.openclaw\\\\workspace-my_work_robot\",\n        \"agentDir\": \"C:\\\\Users\\\\LWS\\\\.openclaw\\\\agents\\\\my_work_robot\\\\agent\",\n        \"model\": \"glm5\"\n      },\n      {\n        \"id\": \"bro_chengbenxia\",\n        \"name\": \"bro_chengbenxia\",\n        \"workspace\": \"C:\\\\Users\\\\LWS\\\\.openclaw\\\\workspace-bro-chengbenxia\",\n        \"agentDir\": \"C:\\\\Users\\\\LWS\\\\.openclaw\\\\agents\\\\bro_chengbenxia\\\\agent\",\n        \"model\": \"kimi\"\n      },\n      {\n        \"id\": \"zx_assistant_01\",\n        \"name\": \"zx_assistant_01\",\n        \"workspace\": \"C:\\\\Users\\\\LWS\\\\.openclaw\\\\workspace-zx_assistant_01\",\n        \"agentDir\": \"C:\\\\Users\\\\LWS\\\\.openclaw\\\\agents\\\\zx_assistant_01\\\\agent\",\n        \"model\": \"minimax\"\n      },\n      {\n        \"id\": \"zx_jiankangxia\",\n        \"name\": \"zx_jiankangxia\",\n        \"workspace\": \"C:\\\\Users\\\\LWS\\\\.openclaw\\\\workspace-zx_jiankangxia\",\n        \"agentDir\": \"C:\\\\Users\\\\LWS\\\\.openclaw\\\\agents\\\\zx_jiankangxia\\\\agent\",\n        \"model\": \"kimi\"\n      },\n      {\n        \"id\": \"zx_robot_01\",\n        \"name\": \"zx_robot_01\",\n        \"workspace\": \"C:\\\\Users\\\\LWS\\\\.openclaw\\\\workspace-zx_robot_01\",\n        \"agentDir\": \"C:\\\\Users\\\\LWS\\\\.openclaw\\\\agents\\\\zx_robot_01\\\\agent\",\n        \"model\": \"minimax\"\n      }\n    ]\n  },\n  \"tools\": {\n    \"profile\": \"full\",\n    \"sessions\": {\n      \"visibility\": \"all\"\n    }\n  },\n  \"bindings\": [\n    {\n      \"agentId\": \"main\",\n      \"match\": {\n        \"channel\": \"feishu\",\n        \"accountId\": \"default\"\n      }\n    },\n    {\n      \"agentId\": \"my_robot_01\",\n      \"match\": {\n        \"channel\": \"feishu\",\n        \"accountId\": \"my_robot_01\"\n      }\n    },\n    {\n      \"agentId\": \"my_xiaohongshu\",\n      \"match\": {\n        \"channel\": \"feishu\",\n        \"accountId\": \"my_xiaohongshu\"\n      }\n    },\n    {\n      \"agentId\": \"my_kuailexia\",\n      \"match\": {\n        \"channel\": \"feishu\",\n        \"accountId\": \"my_kuailexia\"\n      }\n    },\n    {\n      \"agentId\": \"bro_chengbenxia\",\n      \"match\": {\n        \"channel\": \"feishu\",\n        \"accountId\": \"bro_chengbenxia\"\n      }\n    },\n    {\n      \"agentId\": \"my_xiaohongshu\",\n\n[249 more lines in file. Use offset=301 to continue.]"}],"isError":false,"timestamp":1775055154042}}
