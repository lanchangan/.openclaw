f 'results' in result and result['results']:\n            print(f'\\n🔍 找到 {len(result[\\\"results\\\"])} 个结果:\\n')\n            \n            for i, item in enumerate(result['results'], 1):\n                title = item.get('title', '无标题')\n                url = item.get('url', '')\n                content = item.get('content', '无内容')\n                \n                print(f'\\n[{i}] {title}')\n                print(f'    🔗 {url}')\n                if len(content) > 200:\n                    print(f'    📝 {content[:200]}...')\n                else:\n                    print(f'    📝 {content}')\n        \n        print('\\n==================================================')\n        print('搜索完成')\n        print('==================================================')\n        \nexcept Exception as e:\n    print(f'错误: {str(e)}', file=sys.stderr)\n    sys.exit(1)\n\" 2>&1","pty":false,"timeout":60}},{"type":"toolCall","id":"exec:169","name":"exec","arguments":{"command":"& 'C:\\Program Files\\Python314\\python.exe' -c \"\nimport sys\nimport json\nimport urllib.request\nimport ssl\n\nssl._create_default_https_context = ssl._create_unverified_context\n\napi_key = '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'\nquery = '西安 教师招聘 小学语文 2025 编制'\n\nurl = 'https://api.tavily.com/search'\ndata = json.dumps({\n    'api_key': api_key,\n    'query': query,\n    'search_depth': 'advanced',\n    'max_results': 10,\n    'include_domains': ['edu.cn', 'zhaopin.com', '51job.com', '智联招聘.com', '西安教育局', '陕西省教育厅']\n}).encode('utf-8')\n\ntry:\n    req = urllib.request.Request(url, data=data, headers={'Content-Type': 'application/json'}, method='POST')\n    with urllib.request.urlopen(req, timeout=30) as response:\n        result = json.loads(response.read().decode('utf-8'))\n        \n        print('=' * 70)\n        print('Tavily 搜索结果 - 西安小学语文教师招聘（精准搜索）')\n        print('=' * 70)\n        \n        if 'answer' in result and result['answer']:\n            print(f'\\n📋 智能摘要:\\n